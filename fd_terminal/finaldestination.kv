            markup: True
            font_name: font_mono
            size_hint_y: None
            height: dp(30)
            color: term_fg

        MenuButton:
            id: btn_back_id
            text: "< Back"
            # Action bound in Python based on entry context

        # Bottom Spacer
        Widget:
            size_hint_y: 0.2

