<JournalScreen>:
    evidence_list_layout: evidence_list_layout_id
    stories_list_layout: stories_list_layout_id
    evidence_details_title: evidence_details_title_id
    evidence_details_description: evidence_details_description_id
    story_details_title: story_details_title_id
    story_details_description: story_details_description_id
    story_details_scroll: story_details_scroll_id
    content_manager: content_manager_id
    btn_evidence_tab: btn_evidence_tab_id
    btn_stories_tab: btn_stories_tab_id

    BoxLayout:
        orientation: 'vertical'
        padding: app.safe_left + dp(10), app.safe_top + dp(10), app.safe_right + dp(10), app.safe_bottom + dp(10)
        spacing: dp(10)

        # Top Spacer
        Widget:
            size_hint_y: 0.1

        HeaderLabel:
            text: "[b]Journal[/b]"
            halign: 'center'

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)

            ToggleButton:
                id: btn_evidence_tab_id
                text: "Evidence"
                font_name: font_bold
                font_size: dp(16)
                group: 'journal_tabs'
                state: 'down'
                on_press: root.switch_view('evidence')
                background_normal: ''
                background_color: (0.2, 0.2, 0.2, 1)
                color: term_fg

            ToggleButton:
                id: btn_stories_tab_id
                text: "Stories"
                font_name: font_bold
                font_size: dp(16)
                group: 'journal_tabs'
                on_press: root.switch_view('stories')
                background_normal: ''
                background_color: (0.2, 0.2, 0.2, 1)
                color: term_fg

        ScreenManager:
            id: content_manager_id

            Screen:
                name: 'evidence'
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(10)
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.4
                        Label:
                            text: "[b]Items[/b]"
                            markup: True
                            size_hint_y: None
                            height: dp(30)
                            color: term_accent
                        ScrollView:
                            BoxLayout:
                                id: evidence_list_layout_id
                                orientation: 'vertical'
                                spacing: dp(5)
                                size_hint_y: None
                                height: self.minimum_height
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.6
                        Label:
                            id: evidence_details_title_id
                            text: "Select Item"
                            font_name: font_bold
                            size_hint_y: None
                            height: dp(40)
                            color: term_accent
                            markup: True
                        ScrollView:
                            id: evidence_details_scroll_id
                            Label:
                                id: evidence_details_description_id
                                text: "..."
                                markup: True
                                font_name: font_mono
                                font_size: dp(14)
                                text_size: self.width - dp(20), None
                                size_hint_y: None
                                height: self.texture_size[1]
                                valign: 'top'
            Screen:
                name: 'stories'
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(10)
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.4
                        Label:
                            text: "[b]Unlocked Stories[/b]"
                            markup: True
                            size_hint_y: None
                            height: dp(30)
                            color: term_accent
                        ScrollView:
                            BoxLayout:
                                id: stories_list_layout_id
                                orientation: 'vertical'
                                spacing: dp(5)
                                size_hint_y: None
                                height: self.minimum_height
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.6
                        Label:
                            id: story_details_title_id
                            text: "Select Story"
                            font_name: font_bold
                            size_hint_y: None
                            height: dp(40)
                            color: term_accent

                        # --- FIX: Add the ID here ---
                        ScrollView:
                            id: story_details_scroll_id
                        # ----------------------------
                            Label:
                                id: story_details_description_id
                                text: "..."
                                markup: True
                                font_name: font_mono
                                font_size: dp(14)
                                text_size: self.width - dp(20), None
                                size_hint_y: None
                                height: self.texture_size[1]
                                valign: 'top'

        MenuButton:
            text: "< Back"
            on_release: root.go_to_screen('title', 'right')

        # Bottom Spacer
        Widget:
            size_hint_y: 0.2

<TutorialScreen>:
    BoxLayout:
        orientation: 'vertical'

        # --- THE PADDING FIX ---
        # Kivy format: [left, top, right, bottom]
        # dp(50) on top clears all camera notches and status bars.
        # dp(40) on bottom clears the Android gesture navigation pill.
        padding: dp(15), dp(50), dp(15), dp(40)
        spacing: dp(15)

        # Header
        Label:
            text: "[b]How to Play[/b]"
            font_name: font_bold
            font_size: dp(24)
            color: term_accent
            size_hint_y: None
            height: dp(40)
            markup: True

        # The Scrollable Content Area
        ScrollView:
            bar_width: dp(4)
            bar_color: term_fg
            size_hint_y: 1.0  # Explicitly takes all remaining vertical space

            Label:
                id: tutorial_label
                markup: True
                font_name: font_mono
                font_size: dp(15)

                # Text Wrapping Logic
                text_size: self.width - dp(10), None
                size_hint_y: None
                height: self.texture_size[1]

                valign: 'top'
                halign: 'center'

        # Fixed Spacer (Replaces the unpredictable size_hint_y: 0.2)
        Widget:
            size_hint_y: None
            height: dp(10)

        # Back Button
        MenuButton:
            text: "Back to Title"
            on_release: root.go_to_screen('title', 'right')

<InterLevelScreen>:
    title_label: title_label_id
    narrative_label: narrative_label_id

    BoxLayout:
        orientation: 'vertical'
        padding: app.safe_left + dp(20), app.safe_top + dp(20), app.safe_right + dp(20), app.safe_bottom + dp(20)
        spacing: dp(15)

        # Top Spacer
        Widget:
            size_hint_y: None
            height: dp(10)

        HeaderLabel:
            id: title_label_id
            text: "[b]Level Complete![/b]"
            size_hint_y: None
            height: dp(45)

        ScrollView:
            bar_width: dp(4)
            bar_color: 0.1, 0.8, 0.1, 0.5
            Label:
                id: narrative_label_id
                text: ""
                markup: True
                font_name: font_mono
                font_size: dp(16)
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width * 0.9, None
                halign: 'center'
                valign: 'top'

        Widget:
            size_hint_y: None
            height: dp(10)

        MenuButton:
            text: "Continue"
            on_release: root.proceed_to_next_level(self)

        Widget:
            size_hint_y: None
            height: dp(5)

<EvadedHazardEntry>:
    canvas.before:
        Color:
            rgba: (0.15, 0.15, 0.15, 1) if self.selected else (0, 0, 0, 0)
        Rectangle:
            pos: self.pos
            size: self.size

<SettingsScreen>:
    wipe_btn: wipe_data_button_id
    text_slider: slider_id
    sample_text_label: sample_lbl_id
    theme_btn: theme_btn_id
    vol_slider: vol_slider_id

    BoxLayout:
        orientation: 'vertical'
        padding: app.safe_left + dp(40), app.safe_top + dp(40), app.safe_right + dp(40), app.safe_bottom + dp(40)
        spacing: dp(20)

        # Top Spacer
        Widget:
            size_hint_y: 0.1

        HeaderLabel:
            text: "[b]Settings[/b]"
            halign: 'center'
            font_name: app.thematic_font_name

        # --- Text Scale Section ---
        Label:
            text: "Text Size Scale"
            font_name: font_bold
            size_hint_y: None
            height: dp(30)
            color: term_fg

        Slider:
            id: slider_id
            min: 0.8
            max: 1.4
            value: app.text_scale
            step: 0.1
            size_hint_y: None
            height: dp(40)
            on_value: root._on_text_scale_change(self, self.value)

        Label:
            id: sample_lbl_id
            text: f"Sample Text ({app.text_scale:.1f}x)"
            font_name: font_mono
            font_size: sp(16) * app.text_scale
            size_hint_y: None
            height: dp(40)
            color: term_fg

        # --- NEW: Theme Toggle Section ---
        Label:
            text: "Visual Theme"
            font_name: font_bold
            size_hint_y: None
            height: dp(30)
            color: term_fg

        TerminalButton:
            id: theme_btn_id
            text: f"Current Mode: {app.theme_mode}"
            size_hint_y: None
            height: dp(45)
            on_release: root._toggle_theme(self)

        # --- Master Volume Section ---
        Label:
            # FIX: Look at root.current_volume, NOT the slider ID
            text: f"Master Volume ({int(root.current_volume * 100)}%)"
            font_name: font_bold
            size_hint_y: None
            height: dp(30)
            color: term_fg

        Slider:
            id: vol_slider_id
            min: 0.0
            max: 1.0
            step: 0.05

            # FIX: The slider gets its value from root
            value: root.current_volume

            size_hint_y: None
            height: dp(40)
            on_value: root._on_volume_change(self, self.value)

        Button:
            id: wipe_data_button_id
            text: "Erase Meta Progress"
            background_color: 0.8, 0.1, 0.1, 1  # Make it red in the menu too
            size_hint_y: None
            height: dp(50)
            on_release: root.prompt_wipe_data()

        # --- Spacer and Back Button ---
        Widget:
            size_hint_y: 0.1


        MenuButton:
            text: "Back to Title"
            on_release: root._go_back(self)

<MapPopup>:
    size_hint: 0.9, 0.9
    auto_dismiss: True
    map_label: map_label_id

    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)

        # Header
        Label:
            text: "LEVEL MAP"
            font_name: app.thematic_font_name
            font_size: dp(24)
            size_hint_y: None
            height: dp(40)
            color: term_accent

        TerminalPanel:
            size_hint_y: 1
            ScrollView:
                do_scroll_x: True
                do_scroll_y: True
                bar_width: dp(10)
                bar_color: term_fg

                Label:
                    id: map_label_id
                    text: root.map_content
                    font_name: font_mono
                    font_size: dp(14)
                    size_hint: None, None
                    size: self.texture_size
                    padding: dp(20), dp(20)
                    markup: True
                    halign: 'left'
                    valign: 'top'

        TerminalButton:
            text: "CLOSE MAP"
            size_hint_y: None
            height: dp(50)
            on_release: root.dismiss()

